# Resend API key
RESEND_API_KEY=

# Lead inbox email (required)
LEAD_TO_EMAIL=

# Sender identity (optional)
LEAD_FROM_EMAIL=DoDoShark Leads <onboarding@resend.dev>

# Supabase lead sync (server-only, optional)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Sanity project settings (Strictly required for both build and runtime)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional - defaults to http://localhost:3333 in development and https://dodoshark.sanity.studio in production
NEXT_PUBLIC_SANITY_STUDIO_URL=
# Optional - pin the client API version if needed
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Required for Draft Mode / Visual Editing.
# Local dev: put the token in .env.local
# Production: configure this on the deployed frontend as a Cloudflare Worker secret
SANITY_API_READ_TOKEN=
